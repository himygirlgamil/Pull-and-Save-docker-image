
name: x86-64 Pull and Save Docker Image
on:
  workflow_dispatch:
    inputs:
      docker_images:
        description: '请填写 docker 镜像名称 多个用英文逗号分开'
        required: true
        default: 'alpine:latest,busybox:stable-glibc'
      artifact_name:
        description: '请填写制品包名称'
        required: true
        default: 'artifact'

jobs:
  pull_and_package:
    runs-on: ubuntu-22.04
    outputs:
      public_artifacts: true

    steps:
    - name: Checkout repository
      uses: actions/checkout@v4

    - name: Clean up Docker to free space
      run: |
          docker system prune -a -f
          docker volume prune -f

    - name: Pull Docker Images and Package
      run: |
        images="${{ github.event.inputs.docker_images }}"
        IFS=',' read -r -a image_array &lt;&lt;&lt; "$images"
        
        # 定义最大文件大小 (900MB)，单位字节
        MAX_SIZE=943718400 

        for image in "${image_array[@]}"; do
          echo "Processing image: ${image}"
          docker pull "${image}" --platform "linux/amd64"
          
          # 生成文件名
          image_name="${image//\//_}"
          image_name="${image_name//:/_}"
          tar_file="${image_name}-amd64.tar"
          xz_file="${tar_file}.xz"
          
          # 1. 保存镜像
          docker save "${image}" -o "${tar_file}"
          
          # 2. 压缩镜像
          xz -v -T0 -8 "${tar_file}"
          
          # 3. 检查文件大小并决定是否分割
          if [ -f "${xz_file}" ]; then
            file_size=$(stat -c%s "${xz_file}")
            echo "File size of ${xz_file} is ${file_size} bytes."
            
            if [ "$file_size" -gt "$MAX_SIZE" ]; then
              echo "File exceeds 900MB. Splitting..."
              # 使用 split 分割文件，每份 900m，添加后缀 .partaa, .partab 等
              # -d 使用数字后缀 (可选，这里用默认字母后缀更清晰)
              # --additional-suffix=.xz 保持扩展名语义，但实际上 split 后后缀会变
              split -b 900m --verbose "${xz_file}" "${xz_file}.part"
              
              # 删除原始大文件，只保留分割后的部分
              rm "${xz_file}"
              
              echo "Split completed. Files created:"
              ls -lh "${xz_file}.part"*
            else
              echo "File size is within limit. No splitting needed."
            fi
          else
            echo "Error: Compression failed, ${xz_file} not found."
            exit 1
          fi
          
          # 可选：清理未压缩的 tar 文件 (xz 默认会删除源文件，但为了保险起见)
          if [ -f "${tar_file}" ]; then
             rm "${tar_file}"
          fi
        done

    - name: Upload artifact
      uses: actions/upload-artifact@v7
      with:
        name: ${{ github.event.inputs.artifact_name }}
        # 修改路径以匹配分割后的文件 (.part*) 或未分割的文件 (.xz)
        path: |
          ${{ github.workspace }}/*.xz
          ${{ github.workspace }}/*.part*
        archive: false
        retention-days: 1
